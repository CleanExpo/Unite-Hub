# Test runner Dockerfile
FROM node:18-alpine AS base

# Install system dependencies for testing
RUN apk add --no-cache curl postgresql-client python3 py3-pip docker-cli

# Install Python for agent framework testing
RUN pip3 install requests asyncio pydantic

WORKDIR /app

# Copy package files
COPY package.json package-lock.json* pnpm-lock.yaml* ./

# Install Node.js dependencies
RUN \
  if [ -f pnpm-lock.yaml ]; then npm install -g pnpm && pnpm i --frozen-lockfile; \
  elif [ -f package-lock.json ]; then npm ci; \
  else echo "Lockfile not found." && exit 1; \
  fi

# Copy test files and source code
COPY . .

# Install test-specific dependencies
RUN npm install -g tsx ts-node

# Create test reports directory
RUN mkdir -p tests/reports deployments

# Set permissions for test runner
RUN chmod +x tests/comprehensive-parallel-test-suite.ts
RUN chmod +x scripts/auto-test-deployment.ts

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD curl -f http://web:3000/api/health && curl -f http://ai-agents:8000/health || exit 1

# Default command runs comprehensive tests
CMD ["npm", "run", "test:comprehensive"]
