# FastAPI backend environment variables
# Copy to .env.local and fill in values before starting the server.
# File is read by pydantic-settings (env_file = ".env.local").

# ── Project ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=false

# ── CORS ────────────────────────────────────────────────────────────────────
# JSON array of allowed origins.  Add your Vercel URL for production.
# MUST include the Next.js dev port (default 3000 or 3008).
CORS_ORIGINS=["http://localhost:3000","http://localhost:3008"]

# ── API Auth ─────────────────────────────────────────────────────────────────
# Shared secret that Next.js API routes send as "Authorization: Bearer <key>".
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BACKEND_API_KEY=

# ── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION: min 32 chars, not the default placeholder.
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRE_MINUTES=60

# ── Webhooks ─────────────────────────────────────────────────────────────────
# HMAC-SHA256 secret for verifying inbound webhook signatures.
# Leave empty in dev to skip signature verification.
WEBHOOK_SECRET=

# ── Database ─────────────────────────────────────────────────────────────────
# Local Docker PostgreSQL (matches docker-compose.yml defaults).
DATABASE_URL=postgresql+asyncpg://starter_user:local_dev_password@localhost:5433/starter_db

# ── AI Provider ──────────────────────────────────────────────────────────────
# "ollama" (local, free) or "anthropic" (cloud).
# When set to "ollama" the Anthropic key is ignored.
AI_PROVIDER=ollama

# Ollama (local — no API key required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Anthropic — only required when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Optional cloud providers
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=

# ── Model Defaults ────────────────────────────────────────────────────────────
DEFAULT_MODEL=claude-sonnet-4-6
MAX_TOKENS=4096
TEMPERATURE=0.7

# ── MCP Tools (optional) ──────────────────────────────────────────────────────
EXA_API_KEY=
REF_TOOLS_API_KEY=
