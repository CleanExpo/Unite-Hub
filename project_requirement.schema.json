{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project_requirement.schema.json",
  "title": "Project DoD Requirement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requirement_id",
    "project_id",
    "category",
    "description",
    "probe_type",
    "probe_command_or_check",
    "pass_condition",
    "evidence_required",
    "priority",
    "owner_role",
    "hard_gate",
    "status"
  ],
  "properties": {
    "requirement_id": {
      "type": "string",
      "minLength": 3
    },
    "project_id": {
      "type": "string",
      "minLength": 2
    },
    "category": {
      "type": "string",
      "enum": [
        "capability_check",
        "surface_check",
        "route_check",
        "schema_check",
        "integration_check",
        "test_check",
        "deployment_check",
        "evidence_check",
        "dashboard_check",
        "business_readiness_check",
        "owner_approver_check"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "probe_type": {
      "type": "string",
      "enum": [
        "file_exists",
        "route_exists",
        "test_exists",
        "dashboard_artifact_exists",
        "schema_exists",
        "docs_artifact_exists",
        "static_boolean"
      ]
    },
    "probe_command_or_check": {
      "type": "string",
      "minLength": 1
    },
    "pass_condition": {
      "type": "string",
      "minLength": 1
    },
    "evidence_required": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "priority": {
      "type": "string",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    "owner_role": {
      "type": "string",
      "minLength": 2
    },
    "hard_gate": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "missing",
        "blocked",
        "passed",
        "failed",
        "not_applicable"
      ]
    }
  }
}
