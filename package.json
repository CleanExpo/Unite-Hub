{
  "name": "unite-group",
  "version": "1.0.0",
  "private": true,
  "description": "Unite Hub — AI-Powered CRM & Marketing Automation. Next.js 16 + Supabase PostgreSQL.",
  "author": "Unite Group",
  "license": "ISC",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "dev": "next dev -p 3008",
    "dev:all": "turbo run dev",
    "prebuild": "node scripts/validate-env.mjs --ci",
    "build": "next build",
    "validate:env": "node scripts/validate-env.mjs",
    "build:all": "turbo run build",
    "lint": "eslint src/",
    "lint:all": "turbo run lint",
    "type-check": "tsc --noEmit",
    "type-check:all": "turbo run type-check",
    "test": "vitest run",
    "test:all": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "test:coverage:all": "turbo run test:coverage",
    "clean": "rm -rf .next out dist",
    "clean:all": "turbo run clean",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:restart": "docker compose restart",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "docker:logs": "docker compose logs -f",
    "verify": "bash scripts/verify.sh",
    "verify:windows": "powershell -ExecutionPolicy Bypass -File scripts/verify.ps1",
    "deps:check": "bash scripts/dependency-checks.sh",
    "prepare": "husky || true",
    "email-agent": "node scripts/run-email-agent.mjs",
    "content-agent": "node scripts/run-content-agent.mjs",
    "orchestrator": "node scripts/run-orchestrator.mjs",
    "analyze-contacts": "node scripts/analyze-contacts.mjs",
    "seo:research": "node scripts/seo-intelligence.mjs research",
    "seo:full": "node scripts/seo-intelligence.mjs comprehensive",
    "stripe:audit": "node scripts/run-stripe-agent.mjs audit",
    "integrity:check": "node scripts/run-integrity-check.mjs",
    "linear": "node scripts/linear-update.mjs",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/mcp": "^0.0.46",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "^10.4.17",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "critters": "^0.0.23",
    "cross-env": "^10.1.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "glob": "^13.0.3",
    "gray-matter": "^4.0.3",
    "happy-dom": "^12.10.3",
    "inquirer": "^13.2.0",
    "jsdom": "^27.2.0",
    "msw": "^2.0.0",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "pg": "^8.16.3",
    "playwright": "^1.57.0-alpha-2025-11-07",
    "postcss": "^8.4.35",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^3.5.0",
    "supabase": "^2.58.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^1.6.1",
    "xml2js": "^0.6.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@linear/sdk": "^38.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
