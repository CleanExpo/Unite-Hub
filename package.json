{
  "name": "unite-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Unite Hub — AI-Powered CRM & Marketing Automation. Next.js 16 + FastAPI/LangGraph + Supabase PostgreSQL.",
  "author": "Unite Group",
  "license": "ISC",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:restart": "docker compose restart",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "docker:logs": "docker compose logs -f",
    "verify": "bash scripts/verify.sh",
    "verify:windows": "powershell -ExecutionPolicy Bypass -File scripts/verify.ps1",
    "deps:check": "bash scripts/dependency-checks.sh",
    "prepare": "husky",
    "email-agent": "node scripts/run-email-agent.mjs",
    "content-agent": "node scripts/run-content-agent.mjs",
    "orchestrator": "node scripts/run-orchestrator.mjs",
    "analyze-contacts": "node scripts/analyze-contacts.mjs",
    "seo:research": "node scripts/seo-intelligence.mjs research",
    "seo:full": "node scripts/seo-intelligence.mjs comprehensive",
    "stripe:audit": "node scripts/run-stripe-agent.mjs audit",
    "integrity:check": "node scripts/run-integrity-check.mjs"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "brave-search": "^0.9.0",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yml,yaml}": ["prettier --write"]
  }
}
