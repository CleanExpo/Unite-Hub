{
  "type": "module",
  "name": "unite-group",
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:resilient": "cross-env NODE_OPTIONS='--max-old-space-size=6144' DOCKER_BUILD=true next build",
    "build:nuclear": "cross-env NODE_OPTIONS='--max-old-space-size=8192' NEXT_TELEMETRY_DISABLED=1 DISABLE_WEBPACK_CACHE=true next build --no-lint",
    "build:debug": "cross-env NODE_OPTIONS='--max-old-space-size=4096' DEBUG=next:* next build",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "test": "npx ts-node --esm tests/comprehensive-test-runner.ts",
    "docker:build": "docker build -f Dockerfile.resilient -t unite-group:resilient .",
    "docker:build-debug": "docker build -f Dockerfile.resilient --target debug -t unite-group:debug .",
    "docker:build-nuclear": "docker build -f Dockerfile.nuclear -t unite-group:nuclear .",
    "docker:run": "docker run -p 3000:3000 unite-group:resilient",
    "docker:debug": "docker run -it unite-group:debug /bin/sh",
    "verify:standalone": "node -e \"const fs = require('fs'); if (!fs.existsSync('.next/standalone/server.js')) { console.error('ERROR: standalone build failed'); process.exit(1); } else { console.log('✓ Standalone build verified'); }\""
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@hookform/resolvers": "^5.1.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "@tailwindcss/forms": "^0.5.10",
    "beasties": "^0.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "framer-motion": "^12.16.0",
    "lucide-react": "^0.514.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "openai": "^5.3.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.7.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.57.0",
    "recharts": "^2.15.3",
    "resend": "^4.5.2",
    "socket.io": "^4.8.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.58"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
