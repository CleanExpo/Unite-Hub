OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=unite-group

# ─── APM Configuration ───────────────────────────────────────────────────────
ENABLE_APM=false
APM_PROVIDER=none         # datadog | opentelemetry | custom | none
APM_SERVICE_NAME=unite-group
APM_SAMPLE_RATE=0.1       # Production: 0.1 | Staging: 1.0
APM_FLUSH_INTERVAL=10000  # milliseconds

