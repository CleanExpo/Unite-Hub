CONNECTED_APPS_ENABLED=true
SEARCH_SUITE_ENABLED=true
FOUNDER_OS_ENABLED=true
AI_PHILL_ENABLED=true
BOOST_BUMP_ENABLED=true
SEO_LEAK_ENGINE_ENABLED=true

