# Error-Free Deployment Framework - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ================================
# 🔑 REQUIRED VARIABLES (Critical)
# ================================

# Supabase Configuration (Required for database operations)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# ================================
# 🛠️ DEPLOYMENT VARIABLES
# ================================

# Database URL (for direct connections)
DATABASE_URL=postgresql://user:password@host:port/database

# Authentication Secret (for JWT signing)
AUTH_SECRET=your-super-secret-jwt-signing-key-minimum-32-characters

# Base URL of your deployed application
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ================================
# 📧 MONITORING & ALERTS
# ================================

# Email address to receive health alerts and notifications
REPORT_EMAIL=admin@yourdomain.com

# SMTP Configuration for Email Alerts (Optional but recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ================================
# 🔄 VERCEL DEPLOYMENT (CI/CD Only)
# ================================
# Note: These should be set as GitHub Secrets, not in .env files

# VERCEL_TOKEN=your-vercel-token
# VERCEL_ORG_ID=your-org-id
# VERCEL_PROJECT_ID=your-project-id

# ================================
# 🎯 OPTIONAL INTEGRATIONS
# ================================

# Stripe (for payment processing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google OAuth (for authentication)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Additional API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ================================
# 🧪 DEVELOPMENT & TESTING
# ================================

# Development environment flag
NODE_ENV=development

# Debug logging (set to 'true' for verbose logs)
DEBUG=false

# Test database URL (for running tests)
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/test_db

# ================================
# 📝 CONFIGURATION NOTES
# ================================

# 1. REQUIRED VARIABLES:
#    - Must be set for the application to function
#    - Validation will fail if these are missing
#    - Include NEXT_PUBLIC_SUPABASE_URL, ANON_KEY, and SERVICE_ROLE_KEY

# 2. MONITORING SETUP:
#    - REPORT_EMAIL: Where health alerts are sent
#    - SMTP settings: Required for email functionality
#    - Use app-specific passwords for Gmail

# 3. SECURITY BEST PRACTICES:
#    - Never commit .env.local to version control
#    - Use strong, unique values for all secrets
#    - Rotate keys regularly in production
#    - Use different values for development/staging/production

# 4. DEPLOYMENT CONFIGURATION:
#    - Set NEXT_PUBLIC_BASE_URL to your actual domain
#    - Ensure Vercel environment variables match these values
#    - Use GitHub Secrets for CI/CD variables

# 5. SMTP PROVIDERS:
#    Gmail: smtp.gmail.com:587 (use app password)
#    SendGrid: smtp.sendgrid.net:587
#    Mailgun: smtp.mailgun.org:587
#    AWS SES: email-smtp.region.amazonaws.com:587

# ================================
# 🚀 QUICK SETUP CHECKLIST
# ================================

# ✅ 1. Copy this file to .env.local
# ✅ 2. Fill in Supabase credentials
# ✅ 3. Set your domain in NEXT_PUBLIC_BASE_URL
# ✅ 4. Configure SMTP for monitoring alerts
# ✅ 5. Add AUTH_SECRET (generate with: openssl rand -base64 32)
# ✅ 6. Test with: npm run validate
# ✅ 7. Deploy with: npm run deploy

# ================================
# 🔗 HELPFUL LINKS
# ================================

# Supabase Dashboard: https://app.supabase.com/
# Vercel Dashboard: https://vercel.com/dashboard
# GitHub Secrets: https://github.com/your-repo/settings/secrets/actions
# Gmail App Passwords: https://support.google.com/accounts/answer/185833
