# Unite Group - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ===================================
# SUPABASE CONFIGURATION (REQUIRED)
# ===================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===================================
# STRIPE CONFIGURATION (REQUIRED)
# ===================================
# IMPORTANT: Secret key must start with sk_live_ for production
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===================================
# EMAIL SERVICE - RESEND (REQUIRED)
# ===================================
RESEND_API_KEY=your-resend-api-key

# ===================================
# REDIS CONFIGURATION (OPTIONAL)
# ===================================
# Redis is optional - the app will work without it
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===================================
# APPLICATION CONFIGURATION
# ===================================
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Unite Group
NEXT_PUBLIC_APP_VERSION=14.0
NEXT_PUBLIC_CURRENCY=aud
NEXT_PUBLIC_CONSULTATION_PRICE=55000

# ===================================
# AUTHENTICATION & SECURITY
# ===================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://your-domain.com

# ===================================
# AI SERVICES (OPTIONAL)
# ===================================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
GOOGLE_AI_API_KEY=your-google-ai-key

# ===================================
# MONITORING & ANALYTICS (OPTIONAL)
# ===================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
SENTRY_DSN=https://your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ===================================
# DEVELOPMENT & BUILD
# ===================================
# Set to 'true' during build to skip external service connections
BUILDING=false
NODE_ENV=production

# ===================================
# VERCEL DEPLOYMENT (AUTO-SET)
# ===================================
# These are automatically set by Vercel
# VERCEL_ENV=production
# VERCEL_URL=your-deployment-url.vercel.app
# VERCEL_REGION=syd1
# VERCEL_GIT_COMMIT_SHA=commit-hash
# VERCEL_GIT_COMMIT_REF=branch-name
