SEO_LEAK_TOPICALITY_WEIGHT=0.03
SEO_LEAK_SPAM_WEIGHT=0.02
ENFORCE_NO_BLUFF_POLICY=true

# ─── Workspace Defaults ──────────────────────────────────────────────────────
DEFAULT_WORKSPACE_ID=
NEXT_PUBLIC_DEFAULT_WORKSPACE_ID=
DEFAULT_ORG_ID=

# ─── FastAPI Backend (apps/backend) ──────────────────────────────────────────
# See apps/backend/.env.local.example for backend-specific variables
BACKEND_API_KEY=generate-with-openssl-rand-base64-32
JWT_SECRET_KEY=generate-with-openssl-rand-base64-32
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:3000","http://localhost:3008"]
ENVIRONMENT=development   # development | staging | production

# MCP Tools (FastAPI backend)
EXA_API_KEY=
REF_TOOLS_API_KEY=

# ─── Browser Automation ──────────────────────────────────────────────────────
BROWSER_AUTOMATION_ENABLED=false
HEADLESS_MODE_ENABLED=true
PLAYWRIGHT_TEST_MODE=false
SCREENSHOT_CAPTURE_ENABLED=false
VIDEO_RECORDING_ENABLED=false
BOT_DETECTION_AVOIDANCE_ENABLED=false
PROXY_ROTATION_ENABLED=false
SUPPORTED_BROWSERS=chromium
PAGE_LOAD_TIMEOUT_SECONDS=30
ACTION_DELAY_MS=500
NETWORK_TRACKING_ENABLED=false
JS_ERROR_COLLECTION_ENABLED=false

# ─── Custom Webhook ───────────────────────────────────────────────────────────
CUSTOM_WEBHOOK_URL=
