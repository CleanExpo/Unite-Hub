# Unite Group - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ===================================
# SUPABASE CONFIGURATION (REQUIRED)
# ===================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===================================
# STRIPE CONFIGURATION (REQUIRED)
# ===================================
# ⚠️ CRITICAL: DO NOT CONFUSE THESE KEYS! ⚠️
# 
# STRIPE_SECRET_KEY = Backend/Server use only
#   - MUST start with "sk_live_" for production or "sk_test_" for testing
#   - NEVER expose this in client-side code
#   - NEVER use a key starting with "pk_" here!
#
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY = Frontend/Client use
#   - MUST start with "pk_live_" for production or "pk_test_" for testing
#   - Safe to expose in browser/client code
#   - NEVER use a key starting with "sk_" here!
#
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ===================================
# EMAIL SERVICE - RESEND (REQUIRED)
# ===================================
RESEND_API_KEY=re_your-resend-api-key
# Admin email for receiving notifications
ADMIN_EMAIL=admin@your-domain.com

# ===================================
# REDIS CONFIGURATION (OPTIONAL)
# ===================================
# Redis is optional - the app will work without it
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===================================
# APPLICATION CONFIGURATION
# ===================================
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Unite Group
NEXT_PUBLIC_APP_VERSION=14.0
NEXT_PUBLIC_CURRENCY=aud
NEXT_PUBLIC_CONSULTATION_PRICE=55000

# ===================================
# AUTHENTICATION & SECURITY
# ===================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://your-domain.com

# ===================================
# AI SERVICES (OPTIONAL)
# ===================================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
GOOGLE_AI_API_KEY=your-google-ai-key

# ===================================
# MONITORING & ANALYTICS (OPTIONAL)
# ===================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
SENTRY_DSN=https://your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ===================================
# AI SYSTEM CONFIGURATION
# ===================================
AI_MONITORING_ENABLED=true
AI_PREDICTION_THRESHOLD=0.8
AI_DEPLOYMENT_AUTO_ROLLBACK=true
AI_SECURITY_SCAN_INTERVAL=300000
AI_METRICS_RETENTION_DAYS=30

# ===================================
# CARSI INTEGRATION (OPTIONAL)
# ===================================
# For Unite Group + CARSI partnership integration
CARSI_API_URL=https://api.carsi.au
CARSI_API_KEY=your-carsi-api-key-here
CARSI_CLIENT_ID=your-carsi-client-id-here
CARSI_CLIENT_SECRET=your-carsi-client-secret-here
CARSI_SSO_CALLBACK_URL=https://your-domain.com/api/auth/carsi/callback
CARSI_WEBHOOK_SECRET=your-carsi-webhook-secret-here

# ===================================
# WEBHOOK URLS (OPTIONAL)
# ===================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ===================================
# A/B TESTING (PHASE 4)
# ===================================
ENABLE_EXPERIMENTS=true
EXPERIMENT_COOKIE_DOMAIN=.unitegroup.com.au

# ===================================
# DEVELOPMENT & BUILD
# ===================================
# Set to 'true' during build to skip external service connections
BUILDING=false
NODE_ENV=production

# ===================================
# VERCEL DEPLOYMENT (AUTO-SET)
# ===================================
# These are automatically set by Vercel
# VERCEL_ENV=production
# VERCEL_URL=your-deployment-url.vercel.app
# VERCEL_REGION=syd1
# VERCEL_GIT_COMMIT_SHA=commit-hash
# VERCEL_GIT_COMMIT_REF=branch-name
