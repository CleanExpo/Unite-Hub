# Supabase Database Configuration
# Get these from your Supabase project dashboard: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY_HERE

# Email/SMTP Configuration
# Production email service (Gmail, SendGrid, AWS SES, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password-or-app-password
DEFAULT_FROM=no-reply@your-domain.com
ADMIN_EMAIL=admin@your-domain.com

# Payment Processing (Stripe)
# Get from Stripe Dashboard -> Developers -> API Keys
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# Payment Configuration
NEXT_PUBLIC_CURRENCY=aud
NEXT_PUBLIC_CONSULTATION_PRICE=55000 # Example: 550.00 in cents

# Application Configuration
# Your production domain
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Application version (optional but recommended)
NEXT_PUBLIC_APP_VERSION=1.0.0

# CDN Configuration (Optional - Vercel handles this automatically for projects deployed there)
NEXT_PUBLIC_CDN_ENABLED=true
NEXT_PUBLIC_CDN_PROVIDER=vercel
NEXT_PUBLIC_CDN_BASE_URL=https://your-domain.com # Usually same as NEXT_PUBLIC_SITE_URL
ENABLE_CDN_REDIRECT=false