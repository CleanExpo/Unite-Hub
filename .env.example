# Unite-Group — Comprehensive Environment Variable Reference
# Copy to .env.local and populate before running the application.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
#
# Generation helpers:
#   Secret (32-byte hex): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Base64 secret:        openssl rand -base64 32

# ─── Supabase (REQUIRED) ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Connection Pooling via PgBouncer — 60-80% latency reduction (recommended for production)
# Get from: Supabase Dashboard → Database → Connection Pooling
SUPABASE_POOLER_URL=
DATABASE_POOLER_URL=
DATABASE_SESSION_URL=
ENABLE_DB_POOLER=false
DB_POOLER_MODE=transaction   # transaction | session
DB_POOL_SIZE=20              # Dev: 5 | Staging: 10 | Production: 20
DB_IDLE_TIMEOUT=600          # seconds
DB_MAX_LIFETIME=3600         # seconds
DB_CIRCUIT_THRESHOLD=5
DB_CIRCUIT_TIMEOUT=30000
DB_HEALTH_CHECK_INTERVAL=30000
DB_MAX_RETRIES=3
DB_REQUEST_TIMEOUT=30000
DB_RETRY_DELAY_MS=1000

# Direct PostgreSQL connection (FastAPI backend / Docker)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ─── Authentication (REQUIRED) ───────────────────────────────────────────────
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ─── Redis Caching (recommended for production) ───────────────────────────────
# Docker local:          redis://localhost:6379
# DigitalOcean Managed:  rediss://default:password@your-redis.db.ondigitalocean.com:25061
# Upstash (serverless):  set UPSTASH_REDIS_REST_URL instead
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=unite-group:
REDIS_TLS_ENABLED=false
REDIS_MAX_RETRIES=3
REDIS_CONNECT_TIMEOUT=10000
UPSTASH_REDIS_REST_URL=

# ─── Application URLs ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_URL=https://your-domain.com
BACKEND_URL=http://localhost:8000

# ─── Ecosystem Platform URLs (Unite-Group connected systems) ─────────────────
NEXT_PUBLIC_DR_URL=https://disaster-recovery.unitegroupau.com
NEXT_PUBLIC_NRPG_URL=https://nrpg.unitegroupau.com
NEXT_PUBLIC_CARSI_URL=https://carsi.unitegroupau.com
NEXT_PUBLIC_RESTORE_URL=https://restoreassist.unitegroupau.com
NEXT_PUBLIC_SYNTHEX_URL=https://synthex.unitegroupau.com
NEXT_PUBLIC_OPENCLAW_URL=https://openclaw.unitegroupau.com

# ─── AI Providers ────────────────────────────────────────────────────────────
# Priority 1: Anthropic Claude (Extended Thinking, Prompt Caching, latest models)
ANTHROPIC_API_KEY=sk-ant-xxx
# Expose to browser only if using client-side AI features (avoid if possible)
NEXT_PUBLIC_ANTHROPIC_API_KEY=

# Priority 2: OpenRouter (70-80% cost savings for standard AI operations)
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_API_KEY_2=sk-or-v1-xxx-backup

# Priority 3: Google Gemini (Gmail/Google Workspace intelligence)
GOOGLE_AI_API_KEY=your-gemini-api-key
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GEMINI_DAILY_BUDGET=20.00
GEMINI_ALERT_THRESHOLD=16
GEMINI_ENABLE_THINKING=true

# Priority 4: OpenAI (Whisper transcription, DALL-E image generation)
OPENAI_API_KEY=sk-proj-xxx

# Perplexity (SEO research)
PERPLEXITY_API_KEY=pplx-xxx

# AI Budget Controls
AI_DAILY_BUDGET=50.00
AI_MONTHLY_BUDGET=1500.00
AI_ALERT_THRESHOLD=80
AI_ENFORCE_BUDGET=true
ARMY_DAILY_BUDGET_USD=10.00

# FastAPI backend AI provider
AI_PROVIDER=ollama          # ollama | anthropic
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
DEFAULT_MODEL=claude-sonnet-4-6
MAX_TOKENS=4096
TEMPERATURE=0.7

# ─── Stripe (Billing) ────────────────────────────────────────────────────────
# Test keys (development)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_SECRET_KEY_TEST=sk_test_xxx
STRIPE_TEST_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_WEBHOOK_SECRET_TEST=whsec_xxx
STRIPE_TEST_WEBHOOK_SECRET=whsec_xxx

# Live keys (production) — rotate from test keys before go-live
STRIPE_LIVE_SECRET_KEY=sk_live_xxx
STRIPE_SECRET_KEY_LIVE=sk_live_xxx
NEXT_PUBLIC_STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_xxx
STRIPE_LIVE_WEBHOOK_SECRET=whsec_xxx
STRIPE_WEBHOOK_SECRET_LIVE=whsec_xxx

# Price IDs — Starter / Professional / Elite (monthly + annual)
STRIPE_PRICE_ID_STARTER=price_xxx
STRIPE_PRICE_ID_STARTER_ANNUAL=price_xxx
STRIPE_PRICE_ID_PROFESSIONAL=price_xxx
STRIPE_PRICE_ID_PROFESSIONAL_ANNUAL=price_xxx
STRIPE_PRICE_ID_ELITE=price_xxx
STRIPE_PRICE_ID_ELITE_ANNUAL=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_ID_STARTER=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_ID_PROFESSIONAL=price_xxx

# Synthex plan price IDs
STRIPE_PRICE_ID_SYNTHEX_STARTER=price_xxx
STRIPE_PRICE_ID_SYNTHEX_PROFESSIONAL=price_xxx
STRIPE_PRICE_ID_SYNTHEX_ELITE=price_xxx

# Live price IDs (test equivalents above)
STRIPE_LIVE_PRICE_STARTER=price_xxx
STRIPE_LIVE_PRICE_PRO=price_xxx
STRIPE_LIVE_PRICE_ELITE=price_xxx
STRIPE_TEST_PRICE_STARTER=price_xxx
STRIPE_TEST_PRICE_PRO=price_xxx
STRIPE_TEST_PRICE_ELITE=price_xxx

# ─── Email ───────────────────────────────────────────────────────────────────
# Resend (primary transactional email)
RESEND_API_KEY=re_xxx

# SendGrid (alternative)
SENDGRID_API_KEY=SG.xxx

# SMTP fallback
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your@email.com
EMAIL_SERVER_PASSWORD=your-app-password
EMAIL_FROM=noreply@unitegroupau.com
CONTACT_EMAIL=hello@unitegroupau.com
FOUNDER_EMAIL=founder@unitegroupau.com
ALERT_EMAILS=admin@unitegroupau.com,ops@unitegroupau.com
NOTIFICATION_EMAIL_RECIPIENTS=admin@unitegroupau.com
UNSUBSCRIBE_TOKEN_SECRET=generate-with-openssl-rand-base64-32

# Email agent settings
EMAIL_INGESTION_ENABLED=true
EMAIL_CATEGORIZATION_ENABLED=true
EMAIL_SYNC_INTERVAL_MINUTES=15
EMAIL_CACHE_HOURS=1
EMAIL_RETENTION_DAYS=90
MAX_EMAILS_PER_SYNC=100
MAX_ATTACHMENT_SIZE_MB=25
ATTACHMENT_EXTRACTION_ENABLED=true
SIGNATURE_DETECTION_ENABLED=true
THREAD_CLUSTERING_ENABLED=true
THREAD_CLUSTERING_STRATEGY=subject
SPAM_FILTERING_ENABLED=true
HISTORICAL_INGESTION_ENABLED=false
MAX_HISTORICAL_DAYS=90
SYNC_ERROR_NOTIFICATIONS_ENABLED=true
SYNC_INTERVAL_MINUTES=15
SYNC_LOG_RETENTION_DAYS=30
MAX_SYNC_RETRIES=3
MAX_CONCURRENT_SYNCS=5
AUTO_SYNC_ENABLED=true
WEBHOOK_SYNC_ENABLED=false
AUTO_TOKEN_REFRESH_ENABLED=true
TOKEN_REFRESH_BUFFER_MINUTES=10

# ─── Google OAuth & APIs ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=https://your-domain.com/api/integrations/gmail/callback
GOOGLE_REDIRECT_URI=https://your-domain.com/api/integrations/gmail/callback

