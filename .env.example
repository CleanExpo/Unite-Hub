DIGITALOCEAN_API_TOKEN=your-do-api-token
DIGITALOCEAN_ACCESS_TOKEN=your-do-api-token
DIGITALOCEAN_APP_NAME=unite-group
DIGITALOCEAN_APP_ID=
DIGITALOCEAN_REGION=syd

# Netlify (alternative hosting)
NETLIFY_AUTH_TOKEN=

# ─── Convex (real-time backend — optional) ───────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ─── Security & Encryption ───────────────────────────────────────────────────
# Field-level encryption for PII (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Back this up securely — loss = permanent PII data loss
FIELD_ENCRYPTION_KEY=generate-32-byte-hex
ENCRYPTION_ENABLED=true
ENCRYPTION_ALGORITHM=aes-256-gcm
TOKEN_ENCRYPTION_KEY=generate-32-byte-hex
VAULT_ENCRYPTION_KEY=generate-32-byte-hex
VAULT_MASTER_SECRET=generate-32-byte-hex
BROWSER_STATE_ENCRYPTION_KEY=generate-32-byte-hex
SEO_CREDENTIAL_ENCRYPTION_KEY=generate-32-byte-hex
UNITE_HUB_VAULT_TOKEN=generate-with-openssl-rand-base64-32
WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10

# ─── Cron & Automation ───────────────────────────────────────────────────────
# Cron authentication — generate a random string and set in Vercel cron config
CRON_SECRET=generate-with-openssl-rand-base64-32
ENABLE_SUCCESS_CRONS=true

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info            # debug | info | warn | error
LOG_TO_FILE=false         # Set true for persistent log files
LOG_DIR=logs
LOG_RETENTION_DAYS=30
ENABLE_DB_LOGGING=false
ENABLE_TELEMETRY=false
AUDIT_LOGGING_ENABLED=true
GDPR_COMPLIANCE_ENABLED=true
PII_DETECTION_ENABLED=true

# ─── Media & Uploads ─────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100
MAX_ATTACHMENT_SIZE_MB=25

# ─── Feature Flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_DEMO_MODE=false
