# ============================================================
# Unite-Group Nexus 2.0 — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic — Claude AI
ANTHROPIC_API_KEY=sk-ant-xxx

# Xero — Accounting (Phase 4)
# CARSI Xero Account (carsi, restore, ato, synthex, ccw, dr_qld-fallback)
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
# DR Xero Account (dr, nrpg, dr_qld)
DR_CLIENT_ID=your-dr-client-id
DR_CLIENT_SECRET=your-dr-client-secret

# Google — Gmail + Calendar + Drive (Phase 4)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DRIVE_VAULT_FOLDER_ID=your-google-drive-folder-id

# Linear — Project Management (Phase 4)
LINEAR_API_KEY=lin_api_xxx


# Credentials Vault — AES-256-GCM encryption
# Generate key with: openssl rand -hex 32
VAULT_ENCRYPTION_KEY=your-64-char-hex-key-here

# CRON / Scheduled Tasks
CRON_SECRET=your-cron-secret-here
FOUNDER_USER_ID=your-supabase-user-uuid

# Database — Direct PostgreSQL connection + Connection Pooling (PgBouncer)
# Use the Supabase "Direct connection" string for DATABASE_URL
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Set ENABLE_DB_POOLER=true to use Supabase Pooler (60-80% latency reduction)
ENABLE_DB_POOLER=false
DB_POOL_SIZE=10
DB_POOLER_MODE=transaction
DB_IDLE_TIMEOUT=30
DB_MAX_LIFETIME=3600

# Social Platforms
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# YouTube uses existing GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET

# Slack — Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
SLACK_DEFAULT_CHANNEL=#nexus-alerts

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Playwright E2E Testing
PLAYWRIGHT_TEST_EMAIL=your-test-email@example.com
PLAYWRIGHT_TEST_PASSWORD=your-test-password
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000

# WhatsApp Cloud API (Meta Business)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# GitHub
GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=phill-mcgurk

# Gemini — Image generation + vision analysis
GEMINI_API_KEY=

# Apify — Website scraping + screenshot capture
APIFY_API_TOKEN=

# PaperBanana — Academic diagram/infographic generation (optional)
# When absent, all visual types fall back to Gemini
PAPER_BANANA_URL=
