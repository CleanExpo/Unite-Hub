{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "installCommand": "pnpm install",
  "crons": [
    {
      "path": "/api/cron/bookkeeper",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/coaches/life",
      "schedule": "15 21 * * *"
    },
    {
      "path": "/api/cron/coaches/revenue",
      "schedule": "30 21 * * *"
    },
    {
      "path": "/api/cron/coaches/build",
      "schedule": "45 21 * * *"
    },
    {
      "path": "/api/cron/coaches/marketing",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/synthex-monitor",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/content-engine",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/social-publisher",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/video-status",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/ai/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/bookkeeper/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/coaches/*/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/content-engine/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/social-publisher/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/content/generate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/video/generate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/video-status/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
