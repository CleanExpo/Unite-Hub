{
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "installCommand": "npm install -g pnpm@9.15.0 && pnpm install --no-frozen-lockfile",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/agents/continuous-intelligence",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/aido/google-curve/monitor",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/seo/sync-rankings",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/managed/scheduler/weekly",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/founder-briefing",
      "schedule": "0 21 * * 0"
    },
    {
      "path": "/api/cron/document-expiry",
      "schedule": "0 21 * * *"
    }
  ]
}
