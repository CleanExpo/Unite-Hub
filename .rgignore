# ripgrep ignore — keeps searches fast by excluding large/irrelevant directories
# Survives context compaction; re-read if searches start timing out again.

# Build output
.next/
dist/
build/
out/
coverage/

# Dependencies
node_modules/
.pnpm-store/

# Old project (pre-rebuild artefacts)
NodeJS-Starter-V1/
archived/
ai-review/
audit-reports/
reports/
logs/
tasks/
pacts/

# Supabase — 455 migration files slow down all searches
supabase/migrations/
supabase/_archive/

# Python backend venvs and caches
apps/backend/.venv/
apps/backend/__pycache__/
apps/backend/.ruff_cache/
**/__pycache__/
**/*.pyc

# Generated / cache
.turbo/
.vercel/
.ruff_cache/
supabase/.branches/
supabase/.temp/
playwright-report/
.beads/

# Large binary / media
public/
