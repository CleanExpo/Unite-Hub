{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project_coverage_result.schema.json",
  "title": "Project Coverage Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projectId",
    "projectName",
    "coveragePercent",
    "projectDone",
    "falseDonePreventionActive",
    "falseDonePrevented",
    "missingRequirements",
    "blockedRequirements",
    "failedHardGateCount",
    "nextGeneratedJobs"
  ],
  "$defs": {
    "RequirementProbeResult": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "requirementId",
        "projectId",
        "category",
        "description",
        "probeType",
        "probeCommandOrCheck",
        "priority",
        "hardGate",
        "status",
        "passed",
        "probeResult",
        "evidence"
      ],
      "properties": {
        "requirementId": {
          "type": "string"
        },
        "projectId": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "probeType": {
          "type": "string"
        },
        "probeCommandOrCheck": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ]
        },
        "hardGate": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "passed",
            "missing",
            "failed",
            "blocked",
            "not_applicable"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "probeResult": {
          "type": "string",
          "enum": [
            "passed",
            "missing",
            "failed",
            "blocked",
            "not_applicable"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "MissingRequirementJob": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jobId",
        "projectId",
        "requirementId",
        "priority",
        "title",
        "nextAction",
        "evidenceRequired",
        "seniorPmRank",
        "blockedByBoardGate"
      ],
      "properties": {
        "jobId": {
          "type": "string"
        },
        "projectId": {
          "type": "string"
        },
        "requirementId": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ]
        },
        "title": {
          "type": "string"
        },
        "nextAction": {
          "type": "string"
        },
        "evidenceRequired": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "seniorPmRank": {
          "type": "integer",
          "minimum": 1
        },
        "globalRank": {
          "type": "integer",
          "minimum": 1
        },
        "blockedByBoardGate": {
          "type": "boolean"
        }
      }
    }
  },
  "properties": {
    "projectId": {
      "type": "string"
    },
    "projectName": {
      "type": "string"
    },
    "coveragePercent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "projectDone": {
      "type": "boolean"
    },
    "falseDonePreventionActive": {
      "type": "boolean"
    },
    "falseDonePrevented": {
      "type": "boolean"
    },
    "missingRequirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RequirementProbeResult"
      }
    },
    "blockedRequirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RequirementProbeResult"
      }
    },
    "failedHardGateCount": {
      "type": "integer",
      "minimum": 0
    },
    "nextGeneratedJobs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MissingRequirementJob"
      }
    }
  }
}
